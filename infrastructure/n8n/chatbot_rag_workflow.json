{
  "name": "WordPress RAG Chatbot",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "wp-chatbot-rag",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Webhook (WP REST API)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.body.message }}",
        "options": {
          "systemMessage": "Eres el asistente de atencion y reservas de Qamiluna Studio. Habla en espanol natural de Chile, con tono cercano, claro y resolutivo. Responde normalmente en 2 a 4 frases, sin encabezados ni listas salvo que la clienta lo pida. Usa solo informacion obtenida desde knowledge_base y no inventes precios, promociones ni disponibilidad. Interpreta que Qamiluna, Qami Luna y Cami Luna se refieren a Qamiluna Studio. Si la consulta es sobre novia, interpretala como un servicio para novia, no como vida personal. Si falta contexto suficiente, dilo breve y pide solo el siguiente dato util. No menciones QS Manager."
        },
        "agent": "toolsAgent"
      },
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.4,
      "position": [
        256,
        0
      ]
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "={{ $('Webhook (WP REST API)').item.json.body.session_id }}",
        "contextWindowLength": 6
      },
      "name": "Window Buffer Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.2,
      "position": [
        304,
        256
      ]
    },
    {
      "parameters": {
        "qdrantCollection": "wordpress_context",
        "options": {},
        "collectionName": "wordpress_context",
        "collection": "wordpress_context",
        "mode": "retrieve-as-tool",
        "toolName": "knowledge_base",
        "toolDescription": "Busca informacion publica y operativa de Qamiluna Studio sobre servicios, novia civil y fiesta, maquillaje social, precios referenciales, reservas, abono, traslados y tono de atencion.",
        "topK": 6,
        "includeDocumentMetadata": true
      },
      "name": "Qdrant Vector Store Tool",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
      "typeVersion": 1,
      "position": [
        512,
        256
      ]
    },
    {
      "parameters": {
        "options": {},
        "model": "llama-3.3-70b-versatile"
      },
      "name": "Groq Chat Model1",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        128,
        576
      ]
    },
    {
      "parameters": {
        "options": {},
        "model": "sentence-transformers/distilbert-base-nli-mean-tokens"
      },
      "name": "Embeddings HuggingFace Inference",
      "type": "@n8n/n8n-nodes-langchain.embeddingsHuggingFaceInference",
      "typeVersion": 1,
      "position": [
        496,
        480
      ]
    }
  ],
