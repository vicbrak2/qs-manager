{
  "name": "WordPress RAG Chatbot",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "wp-chatbot-rag",
        "responseMode": "responseNode",
        "options": {}
      },
      "name": "Webhook (WP REST API)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.body.message }}",
        "options": {
          "systemMessage": "Eres el asistente virtual de QS Manager, un sistema de gestión de citas y servicios. Tu rol es ayudar a los usuarios a encontrar información sobre servicios disponibles, horarios, precios, profesionales y procedimientos de reserva.\n\nReglas:\n- Responde SIEMPRE en español, de forma clara y amigable.\n- Basa tus respuestas ÚNICAMENTE en la información recuperada de la base de conocimientos (contexto RAG). No inventes datos.\n- Si no encuentras información relevante en el contexto, indica al usuario que no tienes esa información disponible y sugiere que contacte directamente al negocio.\n- Para preguntas sobre disponibilidad en tiempo real o para hacer reservas, indica al usuario que use el formulario de reserva del sitio.\n- Sé conciso: respuestas de máximo 3-4 oraciones salvo que el usuario pida más detalle.\n- Nunca menciones que eres un modelo de lenguaje, n8n, ni la infraestructura técnica."
        }
      },
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.4,
      "position": [250, 0]
    },
    {
      "parameters": {
        "model": "llama3-70b-8192",
        "options": {
          "temperature": 0.3
        }
      },
      "name": "Groq Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1.1,
      "position": [100, 250]
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "={{ $('Webhook (WP REST API)').item.json.body.session_id }}",
        "contextWindowLength": 10
      },
      "name": "Window Buffer Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.2,
      "position": [300, 250]
    },
    {
      "parameters": {
        "mode": "retrieve",
        "collectionName": "wordpress_context",
        "options": {}
      },
      "name": "Qdrant Vector Store Tool",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
      "typeVersion": 1,
      "position": [500, 250]
    },
    {
      "parameters": {},
      "name": "Hugging Face Embeddings",
      "type": "@n8n/n8n-nodes-langchain.embeddingsHuggingFace",
      "typeVersion": 1,
      "position": [500, 450]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ reply: $json.output, session_id: $('Webhook (WP REST API)').item.json.body.session_id }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [500, 0]
    }
  ],
  "connections": {
    "Webhook (WP REST API)": {
      "main": [
        [
          {
            "node": "AI Agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI Agent": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Groq Chat Model": {
      "ai_languageModel": [
        [
          {
            "node": "AI Agent",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "Window Buffer Memory": {
      "ai_memory": [
        [
          {
            "node": "AI Agent",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    },
    "Qdrant Vector Store Tool": {
      "ai_tool": [
        [
          {
            "node": "AI Agent",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    },
    "Hugging Face Embeddings": {
      "ai_embedding": [
        [
          {
            "node": "Qdrant Vector Store Tool",
            "type": "ai_embedding",
            "index": 0
          }
        ]
      ]
    }
  }
}
