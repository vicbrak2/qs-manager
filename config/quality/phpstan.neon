parameters:
  level: 8
  tmpDir: ../../var/cache/phpstan
  paths:
    - ../../app
    - ../../tests
  excludePaths:
    - ../../app/UI/Admin/Assets/node_modules
  bootstrapFiles:
    - ../../vendor/autoload.php
    - phpstan-bootstrap.php
  scanFiles:
    - ../../vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
  ignoreErrors:
    # QuickReplyMatcher se mantiene en el constructor por compatibilidad con el contenedor DI.
    # El bypass fue eliminado intencionalmente — todas las consultas van ahora al LLM vía n8n.
    - identifier: property.onlyWritten
      path: ../../app/Modules/Agents/Infrastructure/N8n/ChatbotGateway.php
