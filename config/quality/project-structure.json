{
  "allowed_root_entries": [
    ".claude",
    ".editorconfig",
    ".env",
    ".env.example",
    ".git",
    ".github",
    ".githooks",
    ".gitignore",
    ".php-cs-fixer.cache",
    ".warp",
    ".vscode",
    "app",
    "assets",
    "composer.json",
    "composer.lock",
    "config",
    "database",
    "dist",
    "docs",
    "infrastructure",
    "phpunit.xml.dist",
    "qs-core.php",
    "README.md",
    "readme.txt",
    "tests",
    "tools",
    "uninstall.php",
    "var",
    "vendor"
  ],
  "restricted_paths": [
    {
      "relative_path": "infrastructure/n8n",
      "description": "solo manifiestos de despliegue, documentacion y workflows",
      "allowed_extensions": ["json", "md", "yml", "yaml"],
      "allowed_filenames": []
    },
    {
      "relative_path": "tools/n8n",
      "description": "solo scripts operativos y archivos de soporte",
      "allowed_extensions": ["js", "json", "md", "php", "ps1", "txt"],
      "allowed_filenames": [],
      "allowed_subdirectories": ["ingestion", "maintenance", "sync", "setup", "testing"]
    },
    {
      "relative_path": "app",
      "description": "codigo fuente principal organizado por subdominios",
      "allowed_extensions": ["php", "json", "md", "jsx", "js", "css", "yaml", "yml"],
      "allowed_filenames": [],
      "allowed_subdirectories": ["Core", "Interfaces", "Modules", "Shared", "UI"],
      "allow_files_at_root": false
    },
    {
      "relative_path": "docs",
      "description": "documentacion tecnica del proyecto",
      "allowed_extensions": ["md", "json", "png", "jpg", "gitkeep", "pdf"],
      "allowed_filenames": [],
      "allowed_subdirectories": ["agents", "api", "architecture", "modules", "quality", "rag", "operations"],
      "allow_files_at_root": true
    }
  ]
}
