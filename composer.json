{
  "name": "qamilunastudio/qs-core",
  "description": "Sistema de gestion interno QamilunaStudio",
  "type": "wordpress-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "php-di/php-di": "^7.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "brain/monkey": "^2.6",
    "phpstan/phpstan": "^1.10",
    "infection/infection": "^0.27",
    "friendsofphp/php-cs-fixer": "^3.0",
    "php-stubs/wordpress-stubs": "^6.9"
  },
  "autoload": {
    "psr-4": {
      "QS\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "QS\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "infection/extension-installer": true
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --configuration phpunit.xml.dist",
    "analyze": "vendor/bin/phpstan analyse --configuration=config/quality/phpstan.neon",
    "format": "vendor/bin/php-cs-fixer fix --config=config/quality/.php-cs-fixer.dist.php"
  }
}
